{
  "tasks": {
    "dev": "deno run --watch mod.ts",
    "test": "deno test --allow-read tests/",
    "test:unit": "deno test --allow-read tests/unit_test.mjs",
    "test:e2e": "deno test --allow-read tests/e2e_test.mjs",
    "test:property": "deno test --allow-read tests/property_test.mjs",
    "test:bench": "deno test --allow-read tests/bench_test.mjs",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "compilerOptions": { "strict": true }
}
